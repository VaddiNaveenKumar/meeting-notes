# ─── Copy this file to .env and fill in your values ───────────────────────────
# NEVER commit .env to version control!

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
DB_URL=jdbc:postgresql://YOUR_SUPABASE_HOST:6543/postgres?prepareThreshold=0
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASS=YOUR_DB_PASSWORD

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_KEY
MAIL_FROM=yourapp@yourdomain.com

# ─── Gemini API Keys (key1 and key2 are required; key3-5 optional) ─────────────
GEMINI_KEY1=YOUR_PRIMARY_GEMINI_KEY
GEMINI_KEY2=YOUR_FALLBACK_GEMINI_KEY
GEMINI_KEY3=
GEMINI_KEY4=
GEMINI_KEY5=

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=YOUR_RANDOM_32_CHAR_SECRET_HERE

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── Notion OAuth (optional) ───────────────────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:5173/notion/callback
